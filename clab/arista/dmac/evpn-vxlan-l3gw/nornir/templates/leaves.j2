{# Get current device data and helper variables #}
{% set device = current_device %}
{% set mgmt_interface = device.interfaces | selectattr('name', 'equalto', 'Management0') | first %}
{% set loopback0 = device.interfaces | selectattr('name', 'equalto', 'Loopback0') | first %}
{% set loopback1 = device.interfaces | selectattr('name', 'equalto', 'Loopback1') | first %}
{% set ethernet_interfaces = [] %}
{% for iface in device.interfaces %}
  {% if iface.name.startswith('Ethernet') %}
    {% set _ = ethernet_interfaces.append(iface) %}
  {% endif %}
{% endfor %}
{% set spine_asn = fabric_asns.spines %}
! GENERAL CONFIG - Role: {{ device.role }}
hostname {{ device.hostname }}
no enable password
no aaa root

! Used for internal VLANs on routed ports. 
vlan internal order ascending range 1000 1200

! Different agents for different routing protocols (ArBGP). 
service routing protocols model multi-agent

! Split 40G interface into 4 x 10G
transceiver qsfp default-mode 4x10G

! USERS
username {{ username }} privilege 15 role network-admin secret 0 {{ password }}

! VRF AND SERVICES
vrf instance {{ mgmt_vrf_name }}

! GNMI
management api gnmi
   transport grpc default
      vrf {{ mgmt_vrf_name }}

! NETCONF
management api netconf
   transport ssh default
      vrf {{ mgmt_vrf_name }}

! eAPI
management api http-commands
   protocol https
   no shutdown
   !
   vrf {{ mgmt_vrf_name }}
      no shutdown

! IP ROUTING
ip routing
no ip routing vrf {{ mgmt_vrf_name }}
ip route vrf MGMT 0.0.0.0/0 172.100.100.1
ipv6 route vrf MGMT ::/0 2001:172:100:100::1

! MGMT INTERFACE
interface Management0
   vrf {{ mgmt_vrf_name }}
   ip address {{ mgmt_interface.ipv4 }}
   ipv6 address {{ mgmt_interface.ipv6 }}

! LOOPBACK INTERFACES
interface Loopback0
   description {{ loopback0.description }}
   no shutdown
   ip address {{ loopback0.ipv4 }}
!
interface Loopback1
   description {{ loopback1.description }}
   no shutdown
   ip address {{ loopback1.ipv4 }}
   
! LEAF-SPINE-INTERFACES
{% for interface in ethernet_interfaces %}
Interface {{ interface.name }}
   description P2P_{{ interface.remote_device | upper }}_{{ interface.remote_interface }}
   no shutdown
   mtu 9214
   no switchport
   ip address {{ interface.ipv4 }}

{% endfor %}
! LEAF-ONLY-CONFIG
! Each Leaf should become a root STP bridge in its own segment to avoid someone else plugin a switch in the access ports and causing that switch to be elected as root or causing a L2 loop.

spanning-tree mode mstp
spanning-tree mst 0 priority 4096

! UNDERLAY
! The aim here is to create BGP Peerings via the physical interfaces between the Leaves and the Spines.
! After the peering has been created, we will advertise the Lo0 via eBGP to be used for peering in the OVerlay (EVPN - Control Plane) and L1 to be used as the VTEP Source IP (VXLAN - Data Plane)

! Define the Loopbacks we want to advertise
ip prefix-list PL-LOOPBACKS seq 10 permit  {{ loopback0.ipv4 }}
ip prefix-list PL-LOOPBACKS seq 20 permit  {{ loopback1.ipv4 }}

! Create a Route Map
route-map RM-UNDERLAY-ADVERTISE permit 10
   match ip address prefix-list PL-LOOPBACKS 

router bgp {{ device.fabric_asn }}
   router-id {{ device.router_id }}
   ! You will not only exchange IPv4 routes but also EVPN routes
   no bgp default ipv4-unicast
   ! ECMP load-balancing across 4 paths if available.
   maximum-paths {{ topology.ecmp_maximum_paths }}
   redistribute connected route-map RM-UNDERLAY-ADVERTISE

   neighbor IPV4-SPINES peer group
   neighbor IPV4-SPINES password 0 {{ secret_bgp_password }}
   neighbor IPV4-SPINES send-community
   neighbor IPV4-SPINES maximum-routes {{ topology.bgp_maximum_routes }}
   neighbor IPV4-SPINES remote-as {{ spine_asn }}
   neighbor IPV4-SPINES route-map RM-UNDERLAY-ADVERTISE out

{% for interface in ethernet_interfaces %}
{# Get the remote spine device and find its interface to this leaf #}
{% set remote_spine = interface.remote_device %}
{% set remote_interface_name = interface.remote_interface %}
{# Find the remote spine's interface to get the IP address #}
{% set spine_devices = topology.spines.devices %}
{% for spine in spine_devices %}
{% if spine.hostname == remote_spine %}
{% for spine_interface in spine.interfaces %}
{% if spine_interface.name == remote_interface_name %}
   ! {{ remote_spine | upper }} BGP Neighbor
   neighbor {{ spine_interface.ipv4.split('/')[0] }} description {{ remote_spine | upper }}_{{ remote_interface_name | upper }}
   neighbor {{ spine_interface.ipv4.split('/')[0] }} peer group IPV4-SPINES
   neighbor {{ spine_interface.ipv4.split('/')[0] }} remote-as {{ spine_asn }}

{% endif %}
{% endfor %}
{% endif %}
{% endfor %}
{% endfor %}
   ! IPv4 Address Family
   address-family ipv4
      neighbor IPV4-SPINES activate
